<% content_for :page_title, "Notifications" %>

<div class="page-header page-header--row">
  <div>
    <h2 class="page-header__title">Notifications</h2>
    <p class="page-header__description">Recent updates about your announcements</p>
  </div>
  <div class="flex-row gap-12">
    <% if @notifications.any?(&:read? == false) %>
      <%= button_to "Mark all as read", mark_read_notifications_path, method: :post, class: "btn btn-secondary" %>
    <% end %>
    <%= link_to "Preferences", edit_notification_preferences_path, class: "btn btn-secondary" %>
  </div>
</div>

<% if @notifications.any? %>
  <div class="card">
    <div class="notification-list">
      <% @notifications.each do |notification| %>
        <div class="notification-item <%= 'notification-item--unread' unless notification.read? %>">
          <div class="notification-item__icon">
            <% if notification.event == "sent" %>
              <span class="notification-dot notification-dot--success"></span>
            <% else %>
              <span class="notification-dot notification-dot--danger"></span>
            <% end %>
          </div>
          <div class="notification-item__content">
            <div class="notification-item__title">
              <strong><%= notification.announcement.title %></strong>
              <% if notification.event == "sent" %>
                <span class="badge badge-success badge--sm">Delivered</span>
              <% else %>
                <span class="badge badge-danger badge--sm">Failed</span>
              <% end %>
            </div>
            <p class="notification-item__summary"><%= notification.summary %></p>
            <span class="notification-item__time"><%= time_ago_in_words(notification.created_at) %> ago</span>
          </div>
          <div class="notification-item__actions">
            <% unless notification.read? %>
              <%= button_to "View", mark_one_read_notification_path(notification), method: :post, class: "btn btn--xs btn-secondary" %>
            <% else %>
              <%= link_to "View", announcement_path(notification.announcement), class: "btn btn--xs btn-secondary" %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% else %>
  <div class="card">
    <div class="empty-state">
      <div class="empty-state__icon">🔔</div>
      <h3>No notifications yet</h3>
      <p class="text-secondary">You'll see updates here when your announcements are delivered or if something goes wrong.</p>
    </div>
  </div>
<% end %>
