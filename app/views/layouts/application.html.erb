<!DOCTYPE html>
<html>
  <head>
    <title>CommsHub - Communication Management</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
  </head>

  <body>
    <!-- Top App Bar -->
    <div class="app-topbar">
      <div class="app-topbar__logo">
        <%= image_tag "jobsity_logo.png", class: "app-topbar__logo-img", alt: "CommsHub" %>
      </div>

      <div class="app-topbar__spacer"></div>

      <div class="app-topbar__notification">
        <% if user_signed_in? %>
          <% unread_count = current_user.notifications.unread.count %>
          <button class="app-topbar__notification-btn" aria-label="Notifications" onclick="this.parentElement.classList.toggle('is-open')">
            🔔
            <% if unread_count > 0 %>
              <span class="notification-badge"><%= unread_count > 9 ? "9+" : unread_count %></span>
            <% end %>
          </button>
          <div class="notification-dropdown">
            <div class="notification-dropdown__header">
              <strong>Notifications</strong>
              <% if unread_count > 0 %>
                <%= button_to "Mark all read", mark_read_notifications_path, method: :post, class: "notification-dropdown__mark-read" %>
              <% end %>
            </div>
            <div class="notification-dropdown__body">
              <% current_user.notifications.recent.each do |notification| %>
                <a href="<%= announcement_path(notification.announcement) %>" class="notification-dropdown__item <%= 'notification-dropdown__item--unread' unless notification.read? %>">
                  <span class="notification-dot notification-dot--<%= notification.event == 'sent' ? 'success' : 'danger' %>"></span>
                  <div class="notification-dropdown__item-content">
                    <div class="notification-dropdown__item-title"><%= truncate(notification.announcement.title, length: 40) %></div>
                    <div class="notification-dropdown__item-summary"><%= truncate(notification.summary, length: 60) %></div>
                    <div class="notification-dropdown__item-time"><%= time_ago_in_words(notification.created_at) %> ago</div>
                  </div>
                </a>
              <% end %>
              <% if current_user.notifications.none? %>
                <div class="notification-dropdown__empty">No notifications yet</div>
              <% end %>
            </div>
            <div class="notification-dropdown__footer">
              <%= link_to "View all notifications", notifications_path %>
            </div>
          </div>
        <% else %>
          <button class="app-topbar__notification-btn" aria-label="Notifications">🔔</button>
        <% end %>
      </div>

      <div class="app-topbar__user">
        <% if user_signed_in? %>
          <div class="app-topbar__user-menu">
            <div class="app-topbar__user-avatar">
              <%= current_user.email[0].upcase %>
            </div>
            <div class="app-topbar__user-dropdown">
              <div class="app-topbar__user-dropdown-inner">
                <div class="app-topbar__user-info">
                  <div class="app-topbar__user-email"><%= current_user.email %></div>
                  <% if current_user.role.present? %>
                    <div class="app-topbar__user-role"><%= current_user.role %></div>
                  <% end %>
                </div>
                <%= link_to "👤 Manage Users", manage_users_path, class: "app-topbar__user-action" %>
                <%= button_to "Logout", destroy_user_session_path, method: :delete, class: "app-topbar__user-action" %>
              </div>
            </div>
          </div>
        <% else %>
          <%= link_to "Login", new_user_session_path, class: "btn btn-primary" %>
        <% end %>
      </div>
    </div>

    <!-- Side Drawer -->
    <nav class="app-drawer">
      <div class="app-drawer__nav">
        <div class="app-drawer__section">
          <%= link_to root_path, class: "app-drawer__link #{controller_name == 'home' ? 'is-active' : ''}" do %>
            <span class="app-drawer__link-icon">🏠</span>
            <span>Home</span>
          <% end %>

          <%= link_to announcements_path, class: "app-drawer__link #{controller_name == 'announcements' ? 'is-active' : ''}" do %>
            <span class="app-drawer__link-icon">📢</span>
            <span>Announcements</span>
          <% end %>

          <%= link_to contacts_path, class: "app-drawer__link #{%w[contacts contact_lists].include?(controller_name) ? 'is-active' : ''}" do %>
            <span class="app-drawer__link-icon">📇</span>
            <span>Contacts</span>
          <% end %>

          <%= link_to audiences_path, class: "app-drawer__link #{controller_name == 'audiences' ? 'is-active' : ''}" do %>
            <span class="app-drawer__link-icon">👥</span>
            <span>Audiences</span>
          <% end %>
        </div>
      </div>

      <div class="app-drawer__settings">
        <%= link_to help_index_path, class: "app-drawer__link #{controller_name == 'help' ? 'is-active' : ''}" do %>
          <span class="app-drawer__link-icon">❓</span>
          <span>Help</span>
        <% end %>

        <%= link_to settings_path, class: "app-drawer__link #{%w[settings users integrations].include?(controller_name) ? 'is-active' : ''}" do %>
          <span class="app-drawer__link-icon">⚙️</span>
          <span>Settings</span>
        <% end %>
      </div>
    </nav>

    <!-- Main Content -->
    <div class="app-layout">
      <div class="app-content">
        <% if notice %>
          <div class="alert alert-success"><%= notice %></div>
        <% end %>
        <% if alert %>
          <div class="alert alert-danger"><%= alert %></div>
        <% end %>

        <%= yield %>
      </div>
    </div>
    <script>
      document.addEventListener('click', function(e) {
        var notif = document.querySelector('.app-topbar__notification');
        if (notif && !notif.contains(e.target)) {
          notif.classList.remove('is-open');
        }
      });
    </script>
  </body>
</html>
