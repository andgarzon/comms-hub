<% content_for :page_title, "New Audience" %>

<div class="page-header">
  <h2 class="page-header__title">Create Audience</h2>
  <p class="page-header__description">Define a new recipient group for your announcements</p>
</div>

<div class="max-w-800">
  <%= form_with(model: @audience, local: true) do |form| %>
    <% if @audience.errors.any? %>
      <div class="alert alert-danger error-list">
        <strong class="error-list__title">
          <%= pluralize(@audience.errors.count, "error") %> prevented this audience from being saved:
        </strong>
        <ul class="error-list__items">
          <% @audience.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="card mb-20">
      <div class="card__header">
        <h3 class="card__title">Channel Type</h3>
      </div>
      <p class="text-secondary text-sm mb-16">Select the delivery channel for this audience</p>

      <div class="grid-2-col">
        <label class="audience-type-option">
          <%= form.radio_button :type, '', checked: @audience.type.blank?, class: "type-radio", id: "type_general" %>
          <div class="type-content">
            <div class="type-icon">👥</div>
            <div class="type-name">General</div>
            <div class="type-desc">A general-purpose audience with platform users as members.</div>
          </div>
        </label>

        <label class="audience-type-option">
          <%= form.radio_button :type, 'SlackAudience', checked: @audience.type == 'SlackAudience', class: "type-radio", id: "type_slack" %>
          <div class="type-content">
            <div class="type-icon">💬</div>
            <div class="type-name">Slack</div>
            <div class="type-desc">Send announcements to a Slack channel.</div>
          </div>
        </label>

        <label class="audience-type-option">
          <%= form.radio_button :type, 'EmailAudience', checked: @audience.type == 'EmailAudience', class: "type-radio", id: "type_email" %>
          <div class="type-content">
            <div class="type-icon">📧</div>
            <div class="type-name">Email</div>
            <div class="type-desc">Send announcements to a list of email addresses.</div>
          </div>
        </label>

        <label class="audience-type-option">
          <%= form.radio_button :type, 'WhatsappAudience', checked: @audience.type == 'WhatsappAudience', class: "type-radio", id: "type_whatsapp" %>
          <div class="type-content">
            <div class="type-icon">📱</div>
            <div class="type-name">WhatsApp</div>
            <div class="type-desc">Send announcements via WhatsApp to phone numbers.</div>
          </div>
        </label>
      </div>

      <div data-react-component="ChannelTypeToggle"
           data-react-props='<%= {
             slackSelector: "#channel-slack-fields",
             emailSelector: "#channel-email-fields",
             whatsappSelector: "#channel-whatsapp-fields"
           }.to_json %>'></div>
    </div>

    <!-- Audience Scope -->
    <div class="card mb-20">
      <div class="card__header">
        <h3 class="card__title">Audience Scope</h3>
      </div>
      <p class="text-secondary text-sm mb-16">Who should be able to see and use this audience?</p>

      <div class="form-group">
        <%= form.label :scope_type, "Scope", class: "form-label" %>
        <%= form.select :scope_type,
            @available_scope_types.map { |st| [st.titleize, st] },
            { prompt: "Select scope..." },
            class: "form-control", id: "audience_scope_type" %>
        <small class="form-hint">
          Personal = only you. Role = everyone with that role. System = everyone (admin only).
        </small>
      </div>

      <div class="form-group mb-0" id="role-scope-field" style="display: none;">
        <%= form.label :scope_value, "Target Role", class: "form-label" %>
        <%= form.select :scope_value,
            @available_roles.map { |r| [r.upcase, r] },
            { include_blank: "Select role..." },
            class: "form-control" %>
      </div>

      <div data-react-component="AudienceScopeToggle"
           data-react-props='<%= { scopeSelector: "#audience_scope_type", roleFieldSelector: "#role-scope-field" }.to_json %>'></div>
    </div>

    <div class="card mb-20">
      <div class="card__header">
        <h3 class="card__title">Basic Information</h3>
      </div>

      <div class="form-group">
        <%= form.label :name, class: "form-label" %>
        <%= form.text_field :name, class: "form-control", placeholder: "e.g., Engineering Team, All Employees" %>
      </div>

      <div class="form-group mb-0">
        <%= form.label :description, class: "form-label" %>
        <%= form.text_area :description, rows: 3, class: "form-control", placeholder: "Describe who this audience includes..." %>
        <small class="form-hint">Optional: Help others understand who's in this audience</small>
      </div>
    </div>

    <!-- Slack-specific fields -->
    <div class="card mb-20 hidden" id="channel-slack-fields">
      <div class="card__header">
        <h3 class="card__title">Slack Settings</h3>
      </div>

      <div class="form-group mb-0">
        <%= form.label :slack_channel, "Slack Channel", class: "form-label" %>
        <%= form.text_field :slack_channel, class: "form-control", placeholder: "#channel-name" %>
        <small class="form-hint">The Slack channel where announcements will be posted</small>
      </div>
    </div>

    <!-- Email-specific fields -->
    <div class="card mb-20 hidden" id="channel-email-fields">
      <div class="card__header">
        <h3 class="card__title">Email Settings</h3>
      </div>

      <div class="form-group mb-0">
        <%= form.label :email_recipients, "Email recipients (one per line or comma-separated)", class: "form-label" %>
        <%= form.text_area :email_recipients, rows: 6, class: "form-control", placeholder: "user@example.com\nanother@example.com" %>
        <small class="form-hint">Enter email addresses separated by commas, semicolons, or new lines</small>
      </div>
    </div>

    <!-- WhatsApp-specific fields -->
    <div class="card mb-20 hidden" id="channel-whatsapp-fields">
      <div class="card__header">
        <h3 class="card__title">WhatsApp Settings</h3>
      </div>

      <div class="form-group mb-0">
        <%= form.label :whatsapp_recipients, "WhatsApp recipients (one per line or comma-separated)", class: "form-label" %>
        <%= form.text_area :whatsapp_recipients, rows: 6, class: "form-control", placeholder: "+1234567890\n+0987654321" %>
        <small class="form-hint">Enter phone numbers with country code, separated by commas, semicolons, or new lines</small>
      </div>
    </div>

    <!-- Contacts Selection -->
    <div class="card mb-20">
      <div class="card__header">
        <h3 class="card__title">Contacts</h3>
      </div>
      <p class="text-secondary text-sm mb-16">Optionally add contacts to this audience individually or by contact list.</p>

      <% if @contact_lists&.any? %>
        <div class="form-group">
          <label class="form-label">Add entire Contact Lists</label>
          <div class="contacts-checklist" style="max-height: 200px; overflow-y: auto; border: 1px solid var(--border-color, #E2E8F0); border-radius: 6px; padding: 12px;">
            <% @contact_lists.each do |list| %>
              <label class="flex-row gap-8 mb-8" style="align-items: center;">
                <input type="checkbox" name="contact_list_ids[]" value="<%= list.id %>">
                <span><%= list.name %></span>
                <span class="text-muted text-sm">(<%= list.active_contacts_count %> contacts)</span>
              </label>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if @contacts&.any? %>
        <div class="form-group mb-0">
          <label class="form-label">Cherry-pick individual contacts</label>
          <input type="text" id="contact-search" class="form-control mb-8" placeholder="Search contacts...">
          <div class="contacts-checklist" id="contacts-checklist" style="max-height: 300px; overflow-y: auto; border: 1px solid var(--border-color, #E2E8F0); border-radius: 6px; padding: 12px;">
            <% @contacts.each do |contact| %>
              <label class="flex-row gap-8 mb-8 contact-check-item" style="align-items: center;" data-name="<%= contact.name.downcase %>" data-email="<%= contact.email&.downcase %>">
                <input type="checkbox" name="contact_ids[]" value="<%= contact.id %>">
                <span><%= contact.name %></span>
                <% if contact.email.present? %>
                  <span class="text-muted text-sm">(<%= contact.email %>)</span>
                <% end %>
                <% if contact.company.present? %>
                  <span class="badge badge-secondary badge--sm"><%= contact.company %></span>
                <% end %>
              </label>
            <% end %>
          </div>
          <small class="form-hint"><%= @contacts.count %> active contacts available</small>
        </div>
      <% else %>
        <p class="text-secondary text-sm">No contacts available. <%= link_to "Add contacts", contacts_path %> first.</p>
      <% end %>
    </div>

    <div class="form-actions">
      <%= link_to "Cancel", audiences_path, class: "btn btn-secondary" %>
      <%= form.submit "Create Audience", class: "btn btn-primary" %>
    </div>
  <% end %>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    var searchInput = document.getElementById('contact-search');
    if (searchInput) {
      searchInput.addEventListener('input', function() {
        var query = this.value.toLowerCase();
        var items = document.querySelectorAll('.contact-check-item');
        items.forEach(function(item) {
          var name = item.getAttribute('data-name') || '';
          var email = item.getAttribute('data-email') || '';
          if (name.includes(query) || email.includes(query)) {
            item.style.display = '';
          } else {
            item.style.display = 'none';
          }
        });
      });
    }
  });
</script>
