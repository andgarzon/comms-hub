<%= form_with(model: contact, local: true) do |form| %>
  <% if contact.errors.any? %>
    <div class="alert alert-danger error-list">
      <strong class="error-list__title">
        <%= pluralize(contact.errors.count, "error") %> prevented this contact from being saved:
      </strong>
      <ul class="error-list__items">
        <% contact.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="card mb-20">
    <div class="card__header">
      <h3 class="card__title">Contact Type</h3>
    </div>

    <div class="form-group">
      <%= form.label :contact_type, "Type", class: "form-label" %>
      <%= form.select :contact_type, Contact::CONTACT_TYPES.map { |t| [t.titleize, t] }, {}, class: "form-control", id: "contact_type_select", onchange: "toggleContactFields()" %>
      <small class="form-hint">Slack Channel is for channels (e.g. #general), not individual people.</small>
    </div>

    <div class="form-group mb-0">
      <%= form.label :name, class: "form-label" %>
      <%= form.text_field :name, class: "form-control", id: "contact_name_input", placeholder: "Full name" %>
    </div>
  </div>

  <div class="card mb-20" id="person-fields">
    <div class="card__header">
      <h3 class="card__title">Contact Details</h3>
    </div>

    <div class="form-group">
      <%= form.label :email, class: "form-label" %>
      <%= form.email_field :email, class: "form-control", placeholder: "email@example.com" %>
    </div>

    <div class="form-group">
      <%= form.label :phone_number, class: "form-label" %>
      <%= form.text_field :phone_number, class: "form-control", placeholder: "+1234567890" %>
    </div>

    <div class="form-group mb-0">
      <%= form.label :slack_username, class: "form-label" %>
      <%= form.text_field :slack_username, class: "form-control", placeholder: "U0123456789 (Slack Member ID)" %>
    </div>
  </div>

  <div class="card mb-20 hidden" id="slack-channel-fields">
    <div class="card__header">
      <h3 class="card__title">Slack Channel</h3>
    </div>

    <div class="form-group mb-0">
      <%= form.label :slack_channel, "Slack Channel ID or Name", class: "form-label" %>
      <%= form.text_field :slack_channel, class: "form-control", placeholder: "#channel-name or C0123456789" %>
      <small class="form-hint">The Slack channel where announcements will be posted</small>
    </div>
  </div>

  <div class="card mb-20" id="organization-fields">
    <div class="card__header">
      <h3 class="card__title">Organization</h3>
    </div>

    <div class="form-group">
      <%= form.label :company, class: "form-label" %>
      <%= form.text_field :company, class: "form-control", placeholder: "Company name" %>
    </div>

    <div class="form-group">
      <%= form.label :department, class: "form-label" %>
      <%= form.text_field :department, class: "form-control", placeholder: "Department" %>
    </div>

    <div class="form-group mb-0">
      <%= form.label :contact_list_id, "Contact List", class: "form-label" %>
      <%= form.select :contact_list_id, contact_lists.map { |l| [l.name, l.id] }, { include_blank: "No list" }, class: "form-control" %>
    </div>
  </div>

  <div class="card mb-20">
    <div class="card__header">
      <h3 class="card__title">Status</h3>
    </div>

    <div class="form-group mb-0">
      <label class="form-label">
        <%= form.check_box :active, class: "form-checkbox" %>
        Active contact
      </label>
      <small class="form-hint">Inactive contacts won't receive announcements.</small>
    </div>
  </div>

  <div class="form-actions">
    <%= link_to "Cancel", contacts_path, class: "btn btn-secondary" %>
    <%= form.submit class: "btn btn-primary" %>
  </div>
<% end %>

<script>
  function toggleContactFields() {
    var typeSelect = document.getElementById('contact_type_select');
    var personFields = document.getElementById('person-fields');
    var slackChannelFields = document.getElementById('slack-channel-fields');
    var organizationFields = document.getElementById('organization-fields');
    var nameInput = document.getElementById('contact_name_input');

    var isSlackChannel = typeSelect.value === 'slack_channel';
    personFields.classList.toggle('hidden', isSlackChannel);
    slackChannelFields.classList.toggle('hidden', !isSlackChannel);
    organizationFields.classList.toggle('hidden', isSlackChannel);
    nameInput.placeholder = isSlackChannel ? 'e.g., Engineering Updates' : 'Full name';
  }

  // Run on initial load and Turbo page visits
  document.addEventListener('turbo:load', toggleContactFields);
  document.addEventListener('DOMContentLoaded', toggleContactFields);
</script>
